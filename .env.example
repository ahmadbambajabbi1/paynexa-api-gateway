# Copy to `.env` in this folder: `cp .env.example .env`
# Loaded automatically via @nestjs/config when you run from `backends/api-gateway`.

# Backends use 5000+; Next.js apps use 3000+ (escrow_web 3000, escrow_admin 3001).
PORT=5000

# Upstream microservices (defaults match local stack).
USER_SERVICE_URL=http://127.0.0.1:5001
TRANSACTION_SERVICE_URL=http://127.0.0.1:5002
ESCROW_SERVICE_URL=http://127.0.0.1:5003
MESSAGING_SERVICE_URL=http://127.0.0.1:5004
PRODUCT_SERVICE_URL=http://127.0.0.1:5005

# CORS: omit or `*` for permissive dev; comma-separated origins in production.
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001

# Session verification on protected gateway routes (proxied to user-service /users/me).
GATEWAY_AUTH_ENABLED=true
